model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-001
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Standard","Student","Results"]

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

ref table Standard
ref table Student
ref table Results
ref table __measures__

ref role Auckland
ref role Canterbury
ref role Otago
ref role Waikato
ref role Wellington

ref cultureInfo en-US

